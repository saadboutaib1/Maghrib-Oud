# Production on Vercel. The browser calls the same Vercel domain, and Vercel proxies /api to InfinityFree.
VITE_API_URL=/api

# Local development only. If VITE_API_URL is not set, the app falls back to http://127.0.0.1:8000/api.
# If you prefer same-origin /api locally, keep VITE_API_URL=/api and enable this Vite proxy target.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
